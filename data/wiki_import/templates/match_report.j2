{% if position != 'manager' %}
{% set player_cell %}{% if players is string or players is mapping %}{{ player_link(lineup_name(players)) }}{% elif players is iterable %}{% for entry in players %}{% if not loop.first %}, {% endif %}{{ player_link(lineup_name(entry)) }}{% endfor %}{% else %}{{ players }}{% endif %}{% endset %}
|-
! {{ position | capitalize }}
|| {{ player_cell }}
{% endif %}
{% endfor %}
{% if match.home_lineup.manager is defined and match.home_lineup.manager %}

|-
! מאמן
|| {{ player_link(lineup_name(match.home_lineup.manager)) }}
{% endif %}

|}
{% else %}
{% for p in match.home_lineup %}
{% set display_name = p.name_hebrew or p.name_english or p.get('name', '') %}
* {{ p.number | default('') }} {{ player_link(display_name) }}{% if p.captain %} (C){% endif %}
{% endfor %}
{% endif %}
{% endif %}

