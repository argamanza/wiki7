== {{ competition }} {{ season_display }} ==

{| class="wikitable"
! מחזור !! תאריך !! אצטדיון !! יריבה !! תוצאה !! צופים
{% for f in fixtures %}
{% set result = f.result | default('') %}
{# §6 ③ fix (2026-06-12 review): venue-aware win/loss colouring via the
   hbs_match_outcome filter. The old direct home_goals>away_goals
   comparison miscategorised every away match. #}
{% set outcome = result | hbs_match_outcome(f.venue) %}
{% if outcome == 'win' %}
{% set row_color = "#d4edda" %}
{% elif outcome == 'loss' %}
{% set row_color = "#f8d7da" %}
{% elif outcome == 'draw' %}
{% set row_color = "#fff3cd" %}
{% else %}
{% set row_color = "" %}
{% endif %}

|-{% if row_color %} style="background:{{ row_color }};"{% endif %}

{# Yellow-triage fix (2026-06-13): build the match-page link target
   through the `match_title` filter so it routes through the SAME
   helper (`_format_match_title`) that `_match_page_title` uses on
   the renderer side. Pre-fix this line inlined a separate format that
   skipped the wikitext sanitization AND used the raw `f.date` (no
   il_date conversion), so the link always pointed at a different
   title than the actual match-report page when (a) the date had a
   weekday prefix, OR (b) the opponent/competition contained a `[`,
   `]`, `{`, `}`, `#`, or `|`. #}
| {{ f.matchday }} || {{ f.date | il_date }} || {{ f.venue }} || {{ f.opponent }} || {% if f.date and f.opponent %}[[{{ f.date | match_title(f.opponent, competition) }}|{{ result }}]]{% else %}{{ result }}{% endif %} || {{ f.attendance }}
{% endfor %}

|}

