{# §6 ③ fix (2026-06-12 review): the Cargo `players.birth_date` column is
   MySQL `Date`, which requires `YYYY-MM-DD`. Passing the human DD/MM/YYYY
   form made MySQL parse it as M/D/Y — every birth past the 12th NULLed,
   earlier ones got day/month swapped. We now pass the raw ISO date as
   `birth_date_iso` (used by Cargo) AND the Israeli-formatted form as
   `birth_date` (used by the visible infobox field). #}
| birth_date = {{ player.birth_date | il_date }}
| birth_date_iso = {{ player.birth_date or '' }}
| birth_place = {{ player.birth_place or '' }}
| nationality = {{ player.nationality | join(', ') if player.nationality else '' }}
| position = {{ player.main_position or '' }}
| other_positions = {{ player.other_positions | join(', ') if player.other_positions else '' }}
| jersey_number = {{ player.current_jersey_number or '' }}
| current_squad = {{ 'Yes' if player.current_squad else 'No' }}
| homegrown = {{ 'Yes' if player.homegrown else 'No' }}
| retired = {{ 'Yes' if player.retired else 'No' }}
| is_captain = {{ 'Yes' if player.is_captain else 'No' }}
| height_cm = {{ player.height_cm or '' }}
| preferred_foot = {{ player.preferred_foot or '' }}
