# wiki7 Environment Variables
# Copy this file to .env and fill in the actual values.
# DO NOT commit .env to version control.

# --- Docker / Database ---
# Password for the MediaWiki database user (used by both MediaWiki and MariaDB)
MEDIAWIKI_DB_PASSWORD=changeme

# Password for the MariaDB wikiuser (should match MEDIAWIKI_DB_PASSWORD)
MYSQL_PASSWORD=changeme

# Root password for the MariaDB instance
MYSQL_ROOT_PASSWORD=changeme_root

# --- MediaWiki Security ---
# Secret key used for session signing and CSRF tokens (64-char hex string)
WG_SECRET_KEY=replace_with_64_char_hex_string

# Upgrade key for the MediaWiki web installer (16-char hex string)
WG_UPGRADE_KEY=replace_with_16_char_hex_string

# --- Scraper ---
# API key for ScraperAPI (used by tmk-scraper)
SCRAPERAPI_KEY=your_scraperapi_key_here

# --- Data pipeline (wiki import) ---
# Bot credentials read by data/run_pipeline.py for the import step.
# Prod values live in the Wiki7BotSecret in AWS Secrets Manager — fetch and
# export them per data/BOT_SETUP.md; for local docker, create the bot user
# with createAndPromote first.
WIKI_BOT_USER=Wiki7Bot
WIKI_BOT_PASS=changeme_bot
